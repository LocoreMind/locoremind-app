---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
  image?: string;
  keywords?: string;
}

const {
  title,
  description = 'LocoreMind AI - Free AI tools powered by open-source models',
  image = 'https://app.locoremind.com/logo.svg',
  keywords = 'AI tools, OCR, text to speech, speech to text, background removal, image upscaler, document QA, free AI, open source AI'
} = Astro.props;

const url = new URL(Astro.url.pathname, Astro.site || 'https://app.locoremind.com');
const canonicalURL = url.toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="LocoreMind AI" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- Schema.org structured data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "LocoreMind AI",
      "url": "https://app.locoremind.com",
      "logo": "https://app.locoremind.com/logo.svg",
      "description": "Free AI tools powered by open-source models. OCR, TTS, STT, background removal, image upscaling, and more.",
      "applicationCategory": "MultimediaApplication",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "publisher": {
        "@type": "Organization",
        "name": "LocoreMind",
        "url": "https://locoremind.com",
        "logo": "https://app.locoremind.com/logo.svg",
        "sameAs": [
          "https://github.com/LocoreMind",
          "https://huggingface.co/LocoreMind"
        ]
      }
    }
    </script>

    <title>{title}</title>
  </head>
  <body class="bg-surface-950 text-surface-100 min-h-screen flex flex-col">
    <nav class="border-b border-surface-800 bg-surface-900/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 text-xl font-bold tracking-tight">
          <img src="/logo.svg" alt="LocoreMind" class="w-8 h-8" />
          <span class="text-white">LocoreMind</span>
          <span class="text-xs font-normal text-surface-400 ml-0.5 border border-surface-700 rounded px-1.5 py-0.5">AI</span>
        </a>
        <div class="hidden md:flex items-center gap-6 text-sm text-surface-300">
          <a href="/#tools" class="hover:text-white transition-colors">Tools</a>
          <a href="/#pricing" class="hover:text-white transition-colors">Pricing</a>
          <a href="https://locoremind.com" target="_blank" rel="noopener" class="hover:text-white transition-colors flex items-center gap-1">
            Platform
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
          <a href="https://huggingface.co/LocoreMind" target="_blank" rel="noopener" class="hover:text-white transition-colors flex items-center gap-1">
            HF Spaces
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-surface-800 py-8 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-surface-400">
        <p>&copy; {new Date().getFullYear()} LocoreMind. All rights reserved.</p>
        <div class="flex gap-4">
          <a href="https://locoremind.com" target="_blank" rel="noopener" class="hover:text-white transition-colors">About LocoreMind</a>
          <a href="/privacy" class="hover:text-white transition-colors">Privacy</a>
          <a href="/terms" class="hover:text-white transition-colors">Terms</a>
          <a href="https://huggingface.co/LocoreMind" target="_blank" rel="noopener" class="hover:text-white transition-colors">Hugging Face</a>
        </div>
      </div>
    </footer>
  </body>
</html>
