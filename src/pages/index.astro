---
import Layout from '../layouts/Layout.astro';
import ToolCard from '../components/ToolCard.astro';

const tools = [
  {
    title: 'OCR - Text Extraction',
    description: 'Extract text from images and scanned documents with high accuracy. Supports multiple languages and handwriting recognition.',
    icon: '📄',
    href: '/tools/ocr',
    category: 'Document',
    badge: 'Popular',
  },
  {
    title: 'Text to Speech',
    description: 'Convert text to natural-sounding speech. Multiple voices, languages, and speaking styles available.',
    icon: '🔊',
    href: '/tools/tts',
    category: 'Audio',
    badge: 'Popular',
  },
  {
    title: 'Speech to Text',
    description: 'Transcribe audio files to text with punctuation and speaker detection. Powered by Whisper.',
    icon: '🎙️',
    href: '/tools/stt',
    category: 'Audio',
  },
  {
    title: 'Background Removal',
    description: 'Remove backgrounds from images instantly. Perfect for product photos, portraits, and design work.',
    icon: '✂️',
    href: '/tools/bg-remove',
    category: 'Image',
    badge: 'Popular',
  },
  {
    title: 'Image Upscaler',
    description: 'Enhance and upscale low-resolution images up to 4x without losing quality using AI super-resolution.',
    icon: '🔍',
    href: '/tools/upscale',
    category: 'Image',
  },
  {
    title: 'Document Q&A',
    description: 'Upload a document and ask questions about its content. AI reads and understands your files.',
    icon: '💬',
    href: '/tools/doc-qa',
    category: 'Document',
  },
  {
    title: 'Image Caption',
    description: 'Generate descriptive captions for images automatically. Great for accessibility and content creation.',
    icon: '🏷️',
    href: '/tools/image-caption',
    category: 'Image',
  },
  {
    title: 'PDF to Markdown',
    description: 'Convert PDF documents to clean, structured Markdown format preserving headings, lists, and tables.',
    icon: '📝',
    href: '/tools/pdf-to-md',
    category: 'Document',
  },
  {
    title: '3D Model Generator',
    description: 'Generate 3D models from text descriptions or single images. Export to GLB, OBJ formats.',
    icon: '🧊',
    href: '/tools/3d-gen',
    category: '3D',
    badge: 'Beta',
  },
];

const categories = ['All', 'Document', 'Audio', 'Image', '3D'];
---

<Layout title="LocoreMind AI - Free AI Tools Powered by Open Source">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--color-primary-900)_0%,_transparent_50%)] opacity-30"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 relative">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 bg-surface-800/60 border border-surface-700 rounded-full px-4 py-1.5 text-sm text-surface-300 mb-6">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          Powered by open-source models on local hardware
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">
          <span class="text-white">Every AI tool you need,</span><br/>
          <span class="bg-gradient-to-r from-primary-400 to-accent-400 bg-clip-text text-transparent">free and open source.</span>
        </h1>
        <p class="mt-6 text-lg text-surface-400 max-w-2xl mx-auto leading-relaxed">
          OCR, TTS, image processing, 3D generation and more — all running on open-source models.
          No data leaves our servers. No API keys needed.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="#tools" class="w-full sm:w-auto px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white font-medium rounded-lg transition-colors text-center">
            Explore Tools
          </a>
          <a href="https://huggingface.co/LocoreMind" target="_blank" rel="noopener" class="w-full sm:w-auto px-6 py-3 border border-surface-700 hover:border-surface-500 text-surface-200 font-medium rounded-lg transition-colors text-center inline-flex items-center justify-center gap-2">
            View on HF Spaces
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-y border-surface-800 bg-surface-900/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-2xl font-bold text-white">9+</div>
          <div class="text-sm text-surface-400 mt-1">AI Tools</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-white">100%</div>
          <div class="text-sm text-surface-400 mt-1">Open Source</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-white">Free</div>
          <div class="text-sm text-surface-400 mt-1">No API Key</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-white">Private</div>
          <div class="text-sm text-surface-400 mt-1">On-device Processing</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools Grid -->
  <section id="tools" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold text-white">AI Tools</h2>
      <p class="text-surface-400 mt-2">Choose a tool to get started</p>
    </div>

    <!-- Category filter -->
    <div class="flex flex-wrap items-center justify-center gap-2 mb-10">
      {categories.map((cat) => (
        <button
          data-category={cat}
          class:list={[
            'category-btn px-4 py-1.5 rounded-full text-sm font-medium border transition-colors',
            cat === 'All'
              ? 'bg-primary-600/20 text-primary-400 border-primary-500/30'
              : 'bg-surface-800/50 text-surface-400 border-surface-700 hover:text-white hover:border-surface-500',
          ]}
        >
          {cat}
        </button>
      ))}
    </div>

    <div id="tools-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {tools.map((tool) => (
        <div data-tool-category={tool.category}>
          <ToolCard {...tool} />
        </div>
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-surface-800 bg-surface-900/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-white">How It Works</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-primary-600/20 border border-primary-500/30 flex items-center justify-center text-primary-400 font-bold mx-auto mb-4">1</div>
          <h3 class="text-lg font-semibold text-white mb-2">Upload your file</h3>
          <p class="text-sm text-surface-400">Drop an image, audio, document, or type your text into the tool.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-primary-600/20 border border-primary-500/30 flex items-center justify-center text-primary-400 font-bold mx-auto mb-4">2</div>
          <h3 class="text-lg font-semibold text-white mb-2">AI processes it</h3>
          <p class="text-sm text-surface-400">Open-source models running on dedicated hardware process your request.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-primary-600/20 border border-primary-500/30 flex items-center justify-center text-primary-400 font-bold mx-auto mb-4">3</div>
          <h3 class="text-lg font-semibold text-white mb-2">Get your result</h3>
          <p class="text-sm text-surface-400">Download the output instantly. No account required, no data stored.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold text-white">Simple Pricing</h2>
      <p class="text-surface-400 mt-2">Start free, upgrade when you need more</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      <div class="rounded-xl border border-surface-800 bg-surface-900/50 p-6">
        <h3 class="text-lg font-semibold text-white">Free</h3>
        <div class="mt-4 mb-6">
          <span class="text-4xl font-bold text-white">$0</span>
          <span class="text-surface-400">/month</span>
        </div>
        <ul class="space-y-3 text-sm text-surface-300">
          <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> 10 uses per tool / day</li>
          <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Max 5MB file size</li>
          <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> All tools included</li>
          <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> No account required</li>
        </ul>
      </div>
      <div class="rounded-xl border border-primary-500/30 bg-surface-900/50 p-6 ring-1 ring-primary-500/20">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-semibold text-white">Pro</h3>
          <span class="text-xs bg-primary-600/20 text-primary-400 border border-primary-500/30 rounded-full px-2 py-0.5">Popular</span>
        </div>
        <div class="mt-4 mb-6">
          <span class="text-4xl font-bold text-white">$9</span>
          <span class="text-surface-400">/month</span>
        </div>
        <ul class="space-y-3 text-sm text-surface-300">
          <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Unlimited uses</li>
          <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Max 50MB file size</li>
          <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Priority processing</li>
          <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> API access</li>
        </ul>
      </div>
      <div class="rounded-xl border border-surface-800 bg-surface-900/50 p-6">
        <h3 class="text-lg font-semibold text-white">Enterprise</h3>
        <div class="mt-4 mb-6">
          <span class="text-4xl font-bold text-white">Custom</span>
        </div>
        <ul class="space-y-3 text-sm text-surface-300">
          <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Dedicated hardware</li>
          <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Custom models</li>
          <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> SLA guarantee</li>
          <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> On-premise option</li>
        </ul>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.category-btn');
    const toolItems = document.querySelectorAll('[data-tool-category]');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');

        buttons.forEach(b => {
          b.classList.remove('bg-primary-600/20', 'text-primary-400', 'border-primary-500/30');
          b.classList.add('bg-surface-800/50', 'text-surface-400', 'border-surface-700');
        });
        btn.classList.remove('bg-surface-800/50', 'text-surface-400', 'border-surface-700');
        btn.classList.add('bg-primary-600/20', 'text-primary-400', 'border-primary-500/30');

        toolItems.forEach(item => {
          if (category === 'All' || item.getAttribute('data-tool-category') === category) {
            (item as HTMLElement).style.display = '';
          } else {
            (item as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  });
</script>
