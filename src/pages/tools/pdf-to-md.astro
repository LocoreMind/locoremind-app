---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="PDF to Markdown"
  description="Free PDF to Markdown converter. Convert PDF documents to clean, structured Markdown format preserving headings, lists, tables, and formatting."
  icon="📝"
  category="Document"
  hfSpaceUrl="https://huggingface.co/spaces/LocoreMind/pdf-to-md"
  keywords="PDF to Markdown, PDF converter, convert PDF to MD, PDF to text, document converter, free PDF tool"
>
  <div class="space-y-6">
    <div>
      <label class="block text-sm font-medium text-surface-300 mb-2">Upload PDF</label>
      <div id="drop-zone" class="border-2 border-dashed border-surface-700 rounded-lg p-10 text-center hover:border-surface-500 transition-colors cursor-pointer">
        <div class="text-4xl mb-3">📝</div>
        <p class="text-surface-400 text-sm">Drag & drop a PDF here, or click to browse</p>
        <p class="text-surface-500 text-xs mt-2">PDF only — Max 20MB</p>
        <input type="file" id="file-input" class="hidden" accept=".pdf" />
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-surface-300 mb-2">Model</label>
      <select class="w-full bg-surface-800 border border-surface-700 rounded-lg px-3 py-2 text-sm text-surface-200 focus:border-primary-500 focus:outline-none">
        <option>MinerU (Recommended)</option>
        <option>Marker</option>
        <option>Nougat</option>
      </select>
    </div>

    <button id="run-btn" class="w-full py-3 bg-primary-600 hover:bg-primary-500 text-white font-medium rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed" disabled>
      Convert to Markdown
    </button>

    <div id="result" class="hidden">
      <div class="flex items-center justify-between mb-2">
        <label class="block text-sm font-medium text-surface-300">Markdown Output</label>
        <button id="copy-btn" class="text-xs text-primary-400 hover:text-primary-300 transition-colors">Copy to clipboard</button>
      </div>
      <div class="bg-surface-800 border border-surface-700 rounded-lg p-4 max-h-80 overflow-y-auto">
        <pre id="result-text" class="text-sm text-surface-200 whitespace-pre-wrap font-mono leading-relaxed"># Sample Document Title

## Introduction

This is a mock demonstration of the PDF to Markdown conversion tool. The actual system uses **MinerU** to parse PDF structure including:

- Headings and subheadings
- Paragraphs and text blocks
- **Bold** and *italic* formatting
- Bulleted and numbered lists

## Tables

| Feature | Supported |
|---------|-----------|
| Text extraction | Yes |
| Table detection | Yes |
| Image extraction | Yes |
| Formula (LaTeX) | Yes |

## Code Blocks

```python
def hello():
    print("Hello from LocoreMind!")
```

## Conclusion

The conversion preserves document structure while outputting clean, readable Markdown.</pre>
      </div>
      <button class="w-full mt-3 py-2 text-sm text-surface-300 hover:text-white border border-surface-700 rounded-lg hover:border-surface-500 transition-colors">Download .md file</button>
    </div>
  </div>
</ToolLayout>

<script>
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const runBtn = document.getElementById('run-btn') as HTMLButtonElement;
  const result = document.getElementById('result')!;
  const copyBtn = document.getElementById('copy-btn')!;
  const resultText = document.getElementById('result-text')!;

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-primary-500'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-primary-500'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-primary-500');
    if (e.dataTransfer?.files.length) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files?.length) handleFile(fileInput.files[0]); });

  function handleFile(file: File) {
    dropZone.innerHTML = `<div class="text-2xl mb-2">📄</div><p class="text-surface-300 text-sm font-medium">${file.name}</p><p class="text-surface-500 text-xs mt-1">${(file.size / 1024 / 1024).toFixed(1)} MB</p>`;
    runBtn.disabled = false;
  }

  runBtn.addEventListener('click', () => {
    runBtn.textContent = 'Converting...';
    runBtn.disabled = true;
    setTimeout(() => {
      result.classList.remove('hidden');
      runBtn.textContent = 'Convert to Markdown';
      runBtn.disabled = false;
    }, 2000);
  });

  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(resultText.textContent || '');
    copyBtn.textContent = 'Copied!';
    setTimeout(() => copyBtn.textContent = 'Copy to clipboard', 2000);
  });
</script>
