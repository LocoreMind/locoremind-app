---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="Speech to Text"
  description="Free online speech to text transcription tool. Transcribe audio files to text with punctuation and speaker detection. Powered by Whisper AI."
  icon="🎙️"
  category="Audio"
  hfSpaceUrl="https://huggingface.co/spaces/LocoreMind/stt"
  keywords="speech to text, STT, audio transcription, voice to text, Whisper, audio to text converter, free transcription tool"
>
  <div class="space-y-6">
    <div>
      <label class="block text-sm font-medium text-surface-300 mb-2">Upload Audio File</label>
      <div id="drop-zone" class="border-2 border-dashed border-surface-700 rounded-lg p-10 text-center hover:border-surface-500 transition-colors cursor-pointer">
        <div class="text-4xl mb-3">🎙️</div>
        <p class="text-surface-400 text-sm">Drag & drop an audio file here, or click to browse</p>
        <p class="text-surface-500 text-xs mt-2">Supports MP3, WAV, M4A, FLAC — Max 25MB</p>
        <input type="file" id="file-input" class="hidden" accept="audio/*" />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-surface-300 mb-2">Language</label>
        <select class="w-full bg-surface-800 border border-surface-700 rounded-lg px-3 py-2 text-sm text-surface-200 focus:border-primary-500 focus:outline-none">
          <option>Auto-detect</option>
          <option>English</option>
          <option>Chinese</option>
          <option>Japanese</option>
          <option>Korean</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-surface-300 mb-2">Model</label>
        <select class="w-full bg-surface-800 border border-surface-700 rounded-lg px-3 py-2 text-sm text-surface-200 focus:border-primary-500 focus:outline-none">
          <option>Whisper Large V3 (Recommended)</option>
          <option>Whisper Medium</option>
          <option>FunASR</option>
        </select>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <input type="checkbox" id="timestamps" class="rounded bg-surface-800 border-surface-600 text-primary-600" />
      <label for="timestamps" class="text-sm text-surface-300">Include timestamps</label>
    </div>

    <button id="run-btn" class="w-full py-3 bg-primary-600 hover:bg-primary-500 text-white font-medium rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed" disabled>
      Transcribe
    </button>

    <div id="result" class="hidden">
      <div class="flex items-center justify-between mb-2">
        <label class="block text-sm font-medium text-surface-300">Transcription</label>
        <button id="copy-btn" class="text-xs text-primary-400 hover:text-primary-300 transition-colors">Copy to clipboard</button>
      </div>
      <div class="bg-surface-800 border border-surface-700 rounded-lg p-4">
        <p id="result-text" class="text-sm text-surface-200 whitespace-pre-wrap leading-relaxed">
[00:00] Welcome to the demonstration of our speech to text system.
[00:04] This mock result shows what a typical transcription looks like when processed by Whisper Large V3.
[00:10] The model can handle multiple speakers, background noise, and various accents with high accuracy.
[00:16] It supports over 90 languages and can auto-detect the spoken language.
        </p>
      </div>
      <div class="flex gap-2 mt-3">
        <button class="flex-1 py-2 text-sm text-surface-300 hover:text-white border border-surface-700 rounded-lg hover:border-surface-500 transition-colors">Download TXT</button>
        <button class="flex-1 py-2 text-sm text-surface-300 hover:text-white border border-surface-700 rounded-lg hover:border-surface-500 transition-colors">Download SRT</button>
      </div>
    </div>
  </div>
</ToolLayout>

<script>
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const runBtn = document.getElementById('run-btn') as HTMLButtonElement;
  const result = document.getElementById('result')!;
  const copyBtn = document.getElementById('copy-btn')!;
  const resultText = document.getElementById('result-text')!;

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-primary-500'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-primary-500'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-primary-500');
    if (e.dataTransfer?.files.length) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files?.length) handleFile(fileInput.files[0]); });

  function handleFile(file: File) {
    dropZone.innerHTML = `<div class="text-2xl mb-2">🎵</div><p class="text-surface-300 text-sm font-medium">${file.name}</p><p class="text-surface-500 text-xs mt-1">${(file.size / 1024 / 1024).toFixed(1)} MB</p>`;
    runBtn.disabled = false;
  }

  runBtn.addEventListener('click', () => {
    runBtn.textContent = 'Transcribing...';
    runBtn.disabled = true;
    setTimeout(() => {
      result.classList.remove('hidden');
      runBtn.textContent = 'Transcribe';
      runBtn.disabled = false;
    }, 2000);
  });

  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(resultText.textContent || '');
    copyBtn.textContent = 'Copied!';
    setTimeout(() => copyBtn.textContent = 'Copy to clipboard', 2000);
  });
</script>
