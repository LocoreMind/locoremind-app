---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="Background Removal"
  description="Free online background remover tool. Remove backgrounds from images instantly. Perfect for product photos, portraits, and design work. AI-powered precision."
  icon="✂️"
  category="Image"
  hfSpaceUrl="https://huggingface.co/spaces/LocoreMind/bg-remove"
  keywords="background remover, remove background, transparent background, product photo editor, portrait background removal, free background eraser"
>
  <div class="space-y-6">
    <div>
      <label class="block text-sm font-medium text-surface-300 mb-2">Upload Image</label>
      <div id="drop-zone" class="border-2 border-dashed border-surface-700 rounded-lg p-10 text-center hover:border-surface-500 transition-colors cursor-pointer">
        <div class="text-4xl mb-3">✂️</div>
        <p class="text-surface-400 text-sm">Drag & drop an image here, or click to browse</p>
        <p class="text-surface-500 text-xs mt-2">Supports PNG, JPG, WebP — Max 10MB</p>
        <input type="file" id="file-input" class="hidden" accept="image/*" />
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-surface-300 mb-2">Model</label>
      <select class="w-full bg-surface-800 border border-surface-700 rounded-lg px-3 py-2 text-sm text-surface-200 focus:border-primary-500 focus:outline-none">
        <option>RMBG-2.0 (Recommended)</option>
        <option>BiRefNet</option>
        <option>SAM 2</option>
      </select>
    </div>

    <button id="run-btn" class="w-full py-3 bg-primary-600 hover:bg-primary-500 text-white font-medium rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed" disabled>
      Remove Background
    </button>

    <div id="result" class="hidden">
      <label class="block text-sm font-medium text-surface-300 mb-2">Result</label>
      <div class="bg-surface-800 border border-surface-700 rounded-lg p-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-xs text-surface-500 mb-2 text-center">Original</p>
            <div class="aspect-square rounded-lg bg-surface-700 flex items-center justify-center">
              <span class="text-surface-500 text-sm">Preview</span>
            </div>
          </div>
          <div>
            <p class="text-xs text-surface-500 mb-2 text-center">Background Removed</p>
            <div class="aspect-square rounded-lg flex items-center justify-center" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2220%22 height=%2220%22><rect width=%2210%22 height=%2210%22 fill=%22%23334155%22/><rect x=%2210%22 y=%2210%22 width=%2210%22 height=%2210%22 fill=%22%23334155%22/><rect x=%2210%22 width=%2210%22 height=%2210%22 fill=%22%231e293b%22/><rect y=%2210%22 width=%2210%22 height=%2210%22 fill=%22%231e293b%22/></svg>');">
              <span class="text-surface-400 text-sm">Result</span>
            </div>
          </div>
        </div>
      </div>
      <button class="w-full mt-3 py-2 text-sm text-surface-300 hover:text-white border border-surface-700 rounded-lg hover:border-surface-500 transition-colors">Download PNG (Transparent)</button>
    </div>
  </div>
</ToolLayout>

<script>
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const runBtn = document.getElementById('run-btn') as HTMLButtonElement;
  const result = document.getElementById('result')!;

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-primary-500'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-primary-500'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-primary-500');
    if (e.dataTransfer?.files.length) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files?.length) handleFile(fileInput.files[0]); });

  function handleFile(file: File) {
    dropZone.innerHTML = `<div class="text-2xl mb-2">🖼️</div><p class="text-surface-300 text-sm font-medium">${file.name}</p><p class="text-surface-500 text-xs mt-1">${(file.size / 1024).toFixed(1)} KB</p>`;
    runBtn.disabled = false;
  }

  runBtn.addEventListener('click', () => {
    runBtn.textContent = 'Processing...';
    runBtn.disabled = true;
    setTimeout(() => {
      result.classList.remove('hidden');
      runBtn.textContent = 'Remove Background';
      runBtn.disabled = false;
    }, 1500);
  });
</script>
