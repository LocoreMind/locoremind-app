---
import ToolLayout from '../../components/ToolLayout.astro';
---

<ToolLayout
  title="Image Upscaler"
  description="Free AI image upscaler tool. Enhance and upscale low-resolution images up to 4x without losing quality using AI super-resolution technology."
  icon="🔍"
  category="Image"
  hfSpaceUrl="https://huggingface.co/spaces/LocoreMind/upscale"
  keywords="image upscaler, upscale image, AI upscaling, enhance image quality, super resolution, enlarge image, free image enhancer"
>
  <div class="space-y-6">
    <div>
      <label class="block text-sm font-medium text-surface-300 mb-2">Upload Image</label>
      <div id="drop-zone" class="border-2 border-dashed border-surface-700 rounded-lg p-10 text-center hover:border-surface-500 transition-colors cursor-pointer">
        <div class="text-4xl mb-3">🔍</div>
        <p class="text-surface-400 text-sm">Drag & drop an image here, or click to browse</p>
        <p class="text-surface-500 text-xs mt-2">Supports PNG, JPG, WebP — Max 5MB</p>
        <input type="file" id="file-input" class="hidden" accept="image/*" />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-surface-300 mb-2">Scale Factor</label>
        <div class="flex gap-2">
          <button class="scale-btn flex-1 py-2 text-sm border border-surface-700 rounded-lg text-surface-400 hover:text-white hover:border-surface-500 transition-colors" data-scale="2">2x</button>
          <button class="scale-btn flex-1 py-2 text-sm border border-primary-500/30 rounded-lg bg-primary-600/20 text-primary-400 transition-colors" data-scale="4">4x</button>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-surface-300 mb-2">Model</label>
        <select class="w-full bg-surface-800 border border-surface-700 rounded-lg px-3 py-2 text-sm text-surface-200 focus:border-primary-500 focus:outline-none">
          <option>Real-ESRGAN (Recommended)</option>
          <option>SwinIR</option>
        </select>
      </div>
    </div>

    <button id="run-btn" class="w-full py-3 bg-primary-600 hover:bg-primary-500 text-white font-medium rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed" disabled>
      Upscale Image
    </button>

    <div id="result" class="hidden">
      <label class="block text-sm font-medium text-surface-300 mb-2">Result</label>
      <div class="bg-surface-800 border border-surface-700 rounded-lg p-4 text-center">
        <div class="aspect-video rounded-lg bg-surface-700 flex items-center justify-center mb-3">
          <div class="text-center">
            <p class="text-surface-400 text-sm">Upscaled preview</p>
            <p class="text-surface-500 text-xs mt-1">512x512 → 2048x2048</p>
          </div>
        </div>
      </div>
      <button class="w-full mt-3 py-2 text-sm text-surface-300 hover:text-white border border-surface-700 rounded-lg hover:border-surface-500 transition-colors">Download Upscaled Image</button>
    </div>
  </div>
</ToolLayout>

<script>
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const runBtn = document.getElementById('run-btn') as HTMLButtonElement;
  const result = document.getElementById('result')!;

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-primary-500'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-primary-500'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-primary-500');
    if (e.dataTransfer?.files.length) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files?.length) handleFile(fileInput.files[0]); });

  function handleFile(file: File) {
    dropZone.innerHTML = `<div class="text-2xl mb-2">🖼️</div><p class="text-surface-300 text-sm font-medium">${file.name}</p><p class="text-surface-500 text-xs mt-1">${(file.size / 1024).toFixed(1)} KB</p>`;
    runBtn.disabled = false;
  }

  document.querySelectorAll('.scale-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.scale-btn').forEach(b => {
        b.classList.remove('border-primary-500/30', 'bg-primary-600/20', 'text-primary-400');
        b.classList.add('border-surface-700', 'text-surface-400');
      });
      btn.classList.remove('border-surface-700', 'text-surface-400');
      btn.classList.add('border-primary-500/30', 'bg-primary-600/20', 'text-primary-400');
    });
  });

  runBtn.addEventListener('click', () => {
    runBtn.textContent = 'Upscaling...';
    runBtn.disabled = true;
    setTimeout(() => {
      result.classList.remove('hidden');
      runBtn.textContent = 'Upscale Image';
      runBtn.disabled = false;
    }, 2000);
  });
</script>
