---
import Layout from '../layouts/Layout.astro';

interface Props {
  title: string;
  description: string;
  icon: string;
  category: string;
  hfSpaceUrl?: string;
  keywords?: string;
}

const { title, description, icon, category, hfSpaceUrl, keywords } = Astro.props;
---

<Layout title={`${title} - LocoreMind AI`} description={description} keywords={keywords}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <a href="/" class="text-sm text-surface-400 hover:text-white transition-colors inline-flex items-center gap-1 mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to all tools
      </a>
      <div class="flex items-center gap-4">
        <span class="text-4xl">{icon}</span>
        <div>
          <h1 class="text-3xl font-bold text-white">{title}</h1>
          <p class="text-surface-400 mt-1">{description}</p>
        </div>
      </div>
      {hfSpaceUrl && (
        <a href={hfSpaceUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 mt-4 text-sm text-accent-400 hover:text-accent-300 transition-colors">
          Try on Hugging Face Space
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      )}
    </div>

    <div class="rounded-xl border border-surface-800 bg-surface-900/50 p-8">
      <slot />
    </div>
  </div>
</Layout>
