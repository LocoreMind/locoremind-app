---
interface Props {
  title: string;
  description: string;
  icon: string;
  href: string;
  badge?: string;
  category: string;
}

const { title, description, icon, href, badge, category } = Astro.props;

const categoryColors: Record<string, string> = {
  'Document': 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  'Audio': 'bg-green-500/10 text-green-400 border-green-500/20',
  'Image': 'bg-purple-500/10 text-purple-400 border-purple-500/20',
  'Video': 'bg-orange-500/10 text-orange-400 border-orange-500/20',
  '3D': 'bg-pink-500/10 text-pink-400 border-pink-500/20',
};

const colorClass = categoryColors[category] || 'bg-surface-700/50 text-surface-300 border-surface-600';
---

<a href={href} class="group block rounded-xl border border-surface-800 bg-surface-900/50 p-6 hover:border-surface-600 hover:bg-surface-800/50 transition-all duration-200">
  <div class="flex items-start justify-between mb-4">
    <div class="text-3xl">{icon}</div>
    <div class="flex gap-2">
      {badge && <span class="text-[10px] font-medium uppercase tracking-wider bg-accent-600/20 text-accent-400 border border-accent-500/20 rounded-full px-2 py-0.5">{badge}</span>}
      <span class={`text-[10px] font-medium uppercase tracking-wider border rounded-full px-2 py-0.5 ${colorClass}`}>{category}</span>
    </div>
  </div>
  <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-primary-400 transition-colors">{title}</h3>
  <p class="text-sm text-surface-400 leading-relaxed">{description}</p>
</a>
